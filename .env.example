# Database
# For pooled hosted Postgres (Render/Supabase), tune Prisma pool behavior explicitly.
# Add `pgbouncer=true` when using a transaction pooler endpoint.
DATABASE_URL=postgresql://campushire:password@localhost:5432/campushire_db?connection_limit=5&pool_timeout=30&connect_timeout=30
# Optional: direct, non-pooled URL for Prisma CLI operations (migrations/introspection)
# DIRECT_URL=postgresql://campushire:password@localhost:5432/campushire_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars!
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:4000/api/auth/linkedin/callback

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=

# Email (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@campushire.in

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_KEY=your-internal-service-key-min-32-chars

# App
API_PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Frontend origin — used to generate clickable links in emails.
# For local development this defaults to http://localhost:3000 if not set.
FRONTEND_URL=http://localhost:3000
