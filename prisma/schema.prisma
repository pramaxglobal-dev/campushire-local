  tenantId                    String            @map("tenant_id")
  contextType                 ChatContextType   @map("context_type")
  applicationId               String?           @map("application_id")
  referralId                  String?           @map("referral_id")
  serviceRequestId            String?           @map("service_request_id")
  collegeRecruiterConnectionId String?          @map("college_recruiter_connection_id")
  courseEnrollmentId            String?          @map("course_enrollment_id")
  createdByUserId             String            @map("created_by_user_id")
  participantUserIds          Json?             @map("participant_user_ids")
  lastMessageAt               DateTime?         @map("last_message_at")
  isClosed                    Boolean           @default(false) @map("is_closed")
  createdAt                   DateTime          @default(now()) @map("created_at")
  updatedAt                   DateTime          @updatedAt @map("updated_at")
  tenant                      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application                 Application?      @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  referral                    FreelanceReferral? @relation(fields: [referralId], references: [id], onDelete: SetNull)
  serviceRequest              ServiceRequest?   @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  collegeRecruiterConnection  CollegeRecruiterConnection? @relation(fields: [collegeRecruiterConnectionId], references: [id], onDelete: SetNull)
  courseEnrollment             CourseEnrollment? @relation(fields: [courseEnrollmentId], references: [id], onDelete: SetNull)
  createdBy                   User              @relation("chat_thread_creator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  messages                    ChatMessage[]

  @@index([tenantId])
  @@index([applicationId])
  @@index([referralId])
  @@index([serviceRequestId])
  @@index([collegeRecruiterConnectionId])
  @@index([courseEnrollmentId])
  @@index([createdByUserId])
  @@index([contextType])
  @@index([isClosed])
  @@map("chat_threads")
}

model ChatMessage {
  id            String       @id @default(cuid())
  tenantId      String       @map("tenant_id")
  threadId      String       @map("thread_id")
  senderUserId  String       @map("sender_user_id")
  messageType   MessageType  @map("message_type")
  body          String?      @db.Text
  fileUrl       String?      @map("file_url")
  fileName      String?      @map("file_name")
  isSystem      Boolean      @default(false) @map("is_system")
  readAt        DateTime?    @map("read_at")
  readByUserId  String?      @map("read_by_user_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  thread        ChatThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender        User         @relation("chat_message_sender", fields: [senderUserId], references: [id], onDelete: Cascade)
  readBy        User?        @relation("chat_message_reader", fields: [readByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([threadId])
  @@index([senderUserId])
  @@index([readByUserId])
  @@index([messageType])
  @@index([createdAt])
  @@map("chat_messages")
}

model Notification {
  id          String              @id @default(cuid())
  tenantId    String?             @map("tenant_id")
  userId      String              @map("user_id")
  type        NotificationType
  channel     NotificationChannel
  title       String
  body        String              @db.Text
  data        Json?
  isRead      Boolean             @default(false) @map("is_read")
  readAt      DateTime?           @map("read_at")
  sentAt      DateTime?           @map("sent_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  tenant      Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([type])
  @@index([channel])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id        String              @id @default(cuid())
  tenantId  String?             @map("tenant_id")
  userId    String              @map("user_id")
  type      NotificationType
  channel   NotificationChannel
  isEnabled Boolean             @default(true) @map("is_enabled")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  tenant    Tenant?             @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@index([tenantId])
  @@index([userId])
  @@index([isEnabled])
  @@map("notification_preferences")
}

model WhiteLabelConfig {
  id             String    @id @default(cuid())
  tenantId       String    @unique @map("tenant_id")
  brandName      String    @map("brand_name")
  logoUrl        String?   @map("logo_url")
  primaryColor   String    @default("#1B3A6B") @map("primary_color")
  accentColor    String    @default("#0EA5E9") @map("accent_color")
  fontFamily     String?   @map("font_family")
  customDomain   String?   @unique @map("custom_domain")
  senderName     String?   @map("sender_name")
  senderEmail    String?   @map("sender_email")
  showPoweredBy  Boolean   @default(true) @map("show_powered_by")
  customCss      String?   @map("custom_css") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([customDomain])
  @@map("white_label_configs")
}

model ActivityLog {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  userId      String?  @map("user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

model AIMatchScore {
  id               String    @id @default(cuid())
  tenantId         String?   @map("tenant_id")
  jobId            String    @map("job_id")
  applicationId    String?   @map("application_id")
  candidateUserId  String    @map("candidate_user_id")
  score            Int
  matchedSkills    Json?     @map("matched_skills")
  missingSkills    Json?     @map("missing_skills")
  reasoning        Json?
  calculatedAt     DateTime  @default(now()) @map("calculated_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  tenant           Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  job              Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  application      Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  candidate        User      @relation(fields: [candidateUserId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateUserId])
  @@index([tenantId])
  @@index([jobId])
  @@index([applicationId])
  @@index([candidateUserId])
  @@index([score])
  @@map("ai_match_scores")
}

model PlatformSetting {
  id          String    @id @default(cuid())
  tenantId    String?   @map("tenant_id")
  key         String    @unique
  value       Json
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("platform_settings")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  tenantId    String?  @map("tenant_id")
  key         String
  plan        Plan
  isEnabled   Boolean  @default(false) @map("is_enabled")
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([tenantId, key, plan])
  @@index([tenantId])
  @@index([plan])
  @@index([isEnabled])
  @@map("feature_flags")
}
