generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  BASIC
  GROWTH
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  COLLEGE_ADMIN
  STUDENT
  JOB_SEEKER
  CORPORATE_RECRUITER
  FREELANCE_RECRUITER
  VENDOR
  TRAINING_PARTNER
}

enum SubRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
}

enum OAuthProvider {
  GOOGLE
  LINKEDIN
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
  ANY
}

enum ProfileVisibility {
  PUBLIC
  COLLEGE_ONLY
  PRIVATE
}

enum CompanySize {
  SIZE_1_10
  SIZE_11_50
  SIZE_51_200
  SIZE_201_500
  SIZE_501_PLUS
}

enum VendorType {
  MANPOWER_SUPPLIER
  DOCUMENT_VERIFIER
  BACKGROUND_CHECK
  PSYCHOMETRIC
  OTHER
}

enum PricingModel {
  PER_REQUEST
  MONTHLY
  CUSTOM
}

enum JobType {
  INTERNSHIP
  APPRENTICESHIP
  FULL_TIME
  PART_TIME
  CONTRACT
}

enum CommissionType {
  PCT_OF_CTC
  FLAT
}

enum CommissionTrigger {
  ON_OFFER
  ON_JOINING
}

enum JobStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  PAUSED
  CLOSED
  EXPIRED
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  SHORTLISTED
  INTERVIEW_R1
  INTERVIEW_R2
  INTERVIEW_R3
  OFFERED
  ACCEPTED
  HIRED
  REJECTED
  WITHDRAWN
  ON_HOLD
}

enum InterviewRound {
  R1
  R2
  R3
  FINAL
  HR
}

enum InterviewMode {
  VIDEO
  PHONE
  IN_PERSON
}

enum InterviewStatus {
  SCHEDULED
  CONFIRMED
  RESCHEDULED
  COMPLETED
  CANCELLED
}

enum InterviewOutcome {
  PASSED
  FAILED
  ON_HOLD
}

enum ConnectionStatus {
  PENDING
  APPROVED
  REJECTED
  DISCONNECTED
}

enum ReferralStatus {
  ACTIVE
  TRIGGERED
  INVOICED
  PAID
  DISPUTED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  DISPUTED
  CANCELLED
}

enum ServiceRequestType {
  DOCUMENT_VERIFICATION
  BACKGROUND_CHECK
  MANPOWER_SUPPLY
  PSYCHOMETRIC
  OTHER
}

enum ServiceRequestStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
}

enum DocumentType {
  RESUME
  MARKSHEET
  DEGREE
  AADHAAR
  PAN
  CERTIFICATE
  OFFER_LETTER
  OTHER
}

enum VerificationStatus {
  UNVERIFIED
  REQUESTED
  VERIFIED
  REJECTED
}

enum EventType {
  PLACEMENT_DRIVE
  WORKSHOP
  SEMINAR
  HACKATHON
  NETWORKING
  OTHER
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum ParticipantStatus {
  REGISTERED
  ATTENDED
  ABSENT
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  DROPPED
}

enum ChatContextType {
  APPLICATION
  REFERRAL
  SERVICE_REQUEST
  COLLEGE_RECRUITER
  COURSE_ENROLLMENT
}

enum MessageType {
  TEXT
  FILE
  SYSTEM
}

enum NotificationType {
  APPLICATION_STATUS
  INTERVIEW_SCHEDULED
  OFFER_RECEIVED
  COMMISSION_TRIGGERED
  DOCUMENT_VERIFIED
  EVENT_REMINDER
  CONNECTION_REQUEST
  JOB_MATCH
  MESSAGE_RECEIVED
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
  PUSH
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Tenant {
  id                          String                      @id @default(cuid())
  name                        String
  slug                        String                      @unique
  plan                        Plan                        @default(FREE)
  isActive                    Boolean                     @default(true) @map("is_active")
  isWhiteLabel                Boolean                     @default(false) @map("is_white_label")
  primaryDomain               String?                     @map("primary_domain")
  supportEmail                String?                     @map("support_email")
  supportPhone                String?                     @map("support_phone")
  timezone                    String                      @default("Asia/Kolkata")
  country                     String                      @default("India")
  settings                    Json?
  createdAt                   DateTime                    @default(now()) @map("created_at")
  updatedAt                   DateTime                    @updatedAt @map("updated_at")
  users                       User[]
  invites                     Invite[]
  jobs                        Job[]
  applications                Application[]
  collegeProfiles             CollegeProfile[]
  studentProfiles             StudentProfile[]
  recruiterProfiles           RecruiterProfile[]
  freelanceRecruiterProfiles  FreelanceRecruiterProfile[]
  vendorProfiles              VendorProfile[]
  trainingPartnerProfiles     TrainingPartnerProfile[]
  collegeRecruiterConnections CollegeRecruiterConnection[]
  freelanceReferrals          FreelanceReferral[]
  invoices                    Invoice[]
  placementEvents             PlacementEvent[]
  courses                     Course[]
  serviceRequests             ServiceRequest[]
  userDocuments               UserDocument[]
  notifications               Notification[]
  notificationPreferences     NotificationPreference[]
  chatThreads                 ChatThread[]
  chatMessages                ChatMessage[]
  activityLogs                ActivityLog[]
  aiMatchScores               AIMatchScore[]
  platformSettings            PlatformSetting[]
  featureFlags                FeatureFlag[]
  whiteLabelConfig            WhiteLabelConfig?

  @@index([plan])
  @@index([isActive])
  @@map("tenants")
}

model User {
  id                            String                      @id @default(cuid())
  tenantId                      String?                     @map("tenant_id")
  tin                           String                      @unique
  email                         String                      @unique
  phone                         String?                     @unique
  passwordHash                  String?                     @map("password_hash")
  firstName                     String                      @map("first_name")
  lastName                      String                      @map("last_name")
  avatarUrl                     String?                     @map("avatar_url")
  headline                      String?
  bio                           String?                     @db.Text
  role                          UserRole
  subRole                       SubRole?                    @map("sub_role")
  profileVisibility             ProfileVisibility           @default(PRIVATE) @map("profile_visibility")
  isApproved                    Boolean                     @default(false) @map("is_approved")
  isEmailVerified               Boolean                     @default(false) @map("is_email_verified")
  isPhoneVerified               Boolean                     @default(false) @map("is_phone_verified")
  isActive                      Boolean                     @default(true) @map("is_active")
  lastLoginAt                   DateTime?                   @map("last_login_at")
  metadata                      Json?
  createdAt                     DateTime                    @default(now()) @map("created_at")
  updatedAt                     DateTime                    @updatedAt @map("updated_at")
  tenant                        Tenant?                     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  refreshTokens                 RefreshToken[]
  emailVerifications            EmailVerification[]
  passwordResets                PasswordReset[]
  oauthAccounts                 OAuthAccount[]
  collegeProfileManaged         CollegeProfile?             @relation("college_admin_user")
  studentProfile                StudentProfile?
  recruiterProfile              RecruiterProfile?
  freelanceRecruiterProfile     FreelanceRecruiterProfile?
  vendorProfile                 VendorProfile?
  trainingPartnerProfile        TrainingPartnerProfile?
  jobSeekerProfile              JobSeekerProfile?
  candidateEducations           CandidateEducation[]
  candidateExperiences          CandidateExperience[]
  candidateCertifications       CandidateCertification[]
  candidateProjects             CandidateProject[]
  createdInvites                Invite[]                    @relation("invite_creator")
  inviteUses                    InviteUse[]
  createdJobs                   Job[]                       @relation("job_creator")
  applications                  Application[]               @relation("application_candidate")
  applicationStatusChanges      ApplicationStatusHistory[]  @relation("application_status_changed_by")
  interviewsAsCandidate         InterviewSlot[]             @relation("interview_candidate")
  interviewsAsInterviewer       InterviewSlot[]             @relation("interview_interviewer")
  savedJobs                     SavedJob[]
  referralsAsCandidate          FreelanceReferral[]         @relation("referral_candidate")
  referralsAsOwner              FreelanceReferral[]         @relation("referral_owner")
  invoicesIssued                Invoice[]                   @relation("invoice_issuer")
  invoicesBilled                Invoice[]                   @relation("invoice_billed_to")
  serviceRequestsRequested      ServiceRequest[]            @relation("service_request_requester")
  serviceRequestsHandled        ServiceRequest[]            @relation("service_request_handler")
  documentVerificationsRequested DocumentVerification[]     @relation("verification_requester")
  documentVerificationsReviewed DocumentVerification[]      @relation("verification_reviewer")
  eventParticipants             EventParticipant[]
  courseEnrollments             CourseEnrollment[]
  userDocuments                 UserDocument[]              @relation("user_documents")
  verifiedDocuments             UserDocument[]              @relation("document_verifier")
  chatThreadsCreated            ChatThread[]                @relation("chat_thread_creator")
  chatMessagesSent              ChatMessage[]               @relation("chat_message_sender")
  notifications                 Notification[]
  notificationPreferences       NotificationPreference[]
  activityLogs                  ActivityLog[]
  aiMatchScores                 AIMatchScore[]
  createdEvents                 PlacementEvent[]            @relation("event_creator")
  createdCourses                Course[]                    @relation("course_creator")
  manpowerCandidateProfiles     ManpowerCandidate[]         @relation("manpower_candidate_user")
  interviewCreatedBy            InterviewSlot[]             @relation("interview_creator")
  chatMessagesRead              ChatMessage[]               @relation("chat_message_reader")
  collegeConnectionsInitiated   CollegeRecruiterConnection[] @relation("college_connection_initiator")
  collegeConnectionsResponded   CollegeRecruiterConnection[] @relation("college_connection_responder")

  @@index([tenantId])
  @@index([role])
  @@index([subRole])
  @@index([isApproved])
  @@index([isActive])
  @@index([profileVisibility])
  @@map("users")
}

model RefreshToken {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  token             String   @unique
  familyId          String?  @map("family_id")
  replacedByTokenId String?  @map("replaced_by_token_id")
  revokedReason     String?  @map("revoked_reason")
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  expiresAt         DateTime @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  lastUsedAt        DateTime? @map("last_used_at")
  createdAt         DateTime @default(now()) @map("created_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model EmailVerification {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  token      String   @unique
  expiresAt  DateTime @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verifications")
}

model PasswordReset {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  token      String   @unique
  expiresAt  DateTime @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_resets")
}

model OAuthAccount {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  provider          OAuthProvider
  providerAccountId String        @map("provider_account_id")
  accessToken       String?       @map("access_token") @db.Text
  refreshToken      String?       @map("refresh_token") @db.Text
  expiresAt         DateTime?     @map("expires_at")
  scope             String?
  idToken           String?       @map("id_token") @db.Text
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([provider])
  @@map("oauth_accounts")
}

model CollegeProfile {
  id               String                      @id @default(cuid())
  tenantId         String                      @map("tenant_id")
  adminUserId      String                      @unique @map("admin_user_id")
  name             String
  slug             String                      @unique
  logoUrl          String?                     @map("logo_url")
  naacGrade        String?                     @map("naac_grade")
  streams          Json?
  website          String?
  placementEmail   String?                     @map("placement_email")
  placementPhone   String?                     @map("placement_phone")
  address          String?                     @db.Text
  city             String?
  state            String?
  pincode          String?
  country          String                      @default("India")
  openForPlacement Boolean                     @default(true) @map("open_for_placement")
  about            String?                     @db.Text
  createdAt        DateTime                    @default(now()) @map("created_at")
  updatedAt        DateTime                    @updatedAt @map("updated_at")
  tenant           Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  adminUser        User                        @relation("college_admin_user", fields: [adminUserId], references: [id], onDelete: Cascade)
  students         StudentProfile[]
  invites          Invite[]
  connections      CollegeRecruiterConnection[]
  events           PlacementEvent[]
  jobs             Job[]

  @@index([tenantId])
  @@index([openForPlacement])
  @@map("college_profiles")
}

model StudentProfile {
  id                    String        @id @default(cuid())
  userId                String        @unique @map("user_id")
  tenantId              String        @map("tenant_id")
  collegeProfileId      String        @map("college_profile_id")
  enrollmentNumber      String?       @map("enrollment_number")
  program               String?
  department            String?
  yearOfStudy           Int?          @map("year_of_study")
  graduationYear        Int?          @map("graduation_year")
  cgpa                  Float?
  skills                Json?
  resumeUrl             String?       @map("resume_url")
  careerScore           Int           @default(0) @map("career_score")
  isProfileComplete     Boolean       @default(false) @map("is_profile_complete")
  preferredWorkMode     WorkMode      @default(ANY) @map("preferred_work_mode")
  preferredLocations    Json?         @map("preferred_locations")
  expectedCtcMin        Int?          @map("expected_ctc_min")
  expectedCtcMax        Int?          @map("expected_ctc_max")
  linkedInUrl           String?       @map("linkedin_url")
  githubUrl             String?       @map("github_url")
  portfolioUrl          String?       @map("portfolio_url")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  collegeProfile        CollegeProfile @relation(fields: [collegeProfileId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([collegeProfileId])
  @@index([careerScore])
  @@index([isProfileComplete])
  @@map("student_profiles")
}

model RecruiterProfile {
  id                  String                      @id @default(cuid())
  userId              String                      @unique @map("user_id")
  tenantId            String                      @map("tenant_id")
  companyName         String                      @map("company_name")
  companySlug         String                      @unique @map("company_slug")
  industry            String?
  companySize         CompanySize                 @default(SIZE_1_10) @map("company_size")
  website             String?
  logoUrl             String?                     @map("logo_url")
  headquarters        String?
  hiringNow           Boolean                     @default(false) @map("hiring_now")
  isVerified          Boolean                     @default(false) @map("is_verified")
  about               String?                     @db.Text
  culture             String?                     @db.Text
  openJobsCount       Int                         @default(0) @map("open_jobs_count")
  createdAt           DateTime                    @default(now()) @map("created_at")
  updatedAt           DateTime                    @updatedAt @map("updated_at")
  user                User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant              Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobs                Job[]
  connections         CollegeRecruiterConnection[]
  referrals           FreelanceReferral[]
  serviceRequests     ServiceRequest[]
  events              PlacementEvent[]

  @@index([tenantId])
  @@index([companyName])
  @@index([hiringNow])
  @@index([isVerified])
  @@map("recruiter_profiles")
}

model FreelanceRecruiterProfile {
  id                      String           @id @default(cuid())
  userId                  String           @unique @map("user_id")
  tenantId                String           @map("tenant_id")
  agencyName              String?          @map("agency_name")
  isAgency                Boolean          @default(false) @map("is_agency")
  specialization          Json?
  commissionPreference    CommissionType?  @map("commission_preference")
  defaultCommissionValue  Float?           @map("default_commission_value")
  isVerified              Boolean          @default(false) @map("is_verified")
  totalReferrals          Int              @default(0) @map("total_referrals")
  createdAt               DateTime         @default(now()) @map("created_at")
  updatedAt               DateTime         @updatedAt @map("updated_at")
  user                    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant                  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  referrals               FreelanceReferral[]

  @@index([tenantId])
  @@index([isVerified])
  @@map("freelance_recruiter_profiles")
}

model VendorProfile {
  id              String         @id @default(cuid())
  userId          String         @unique @map("user_id")
  tenantId        String         @map("tenant_id")
  vendorType      VendorType     @map("vendor_type")
  businessName    String         @map("business_name")
  pricingModel    PricingModel   @map("pricing_model")
  basePrice       Float?         @map("base_price")
  serviceAreas    Json?          @map("service_areas")
  turnaroundHours Int?           @map("turnaround_hours")
  isVerified      Boolean        @default(false) @map("is_verified")
  isActive        Boolean        @default(true) @map("is_active")
  about           String?        @db.Text
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceRequests ServiceRequest[]
  verifications   DocumentVerification[]

  @@index([tenantId])
  @@index([vendorType])
  @@index([isVerified])
  @@index([isActive])
  @@map("vendor_profiles")
}

model TrainingPartnerProfile {
  id                String        @id @default(cuid())
  userId            String        @unique @map("user_id")
  tenantId          String        @map("tenant_id")
  organizationName  String        @map("organization_name")
  website           String?
  logoUrl           String?       @map("logo_url")
  isVerified        Boolean       @default(false) @map("is_verified")
  platformFeePct    Float         @default(0) @map("platform_fee_pct")
  about             String?       @db.Text
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courses           Course[]
  courseRevenues    CourseRevenue[]

  @@index([tenantId])
  @@index([isVerified])
  @@map("training_partner_profiles")
}

model JobSeekerProfile {
  id                 String     @id @default(cuid())
  userId             String     @unique @map("user_id")
  totalExperienceMonths Int     @default(0) @map("total_experience_months")
  currentCity        String?    @map("current_city")
  preferredLocations Json?      @map("preferred_locations")
  skills             Json?
  expectedCtcMin     Int?       @map("expected_ctc_min")
  expectedCtcMax     Int?       @map("expected_ctc_max")
  availableFrom      DateTime?  @map("available_from")
  resumeUrl          String?    @map("resume_url")
  careerScore        Int        @default(0) @map("career_score")
  isProfileComplete  Boolean    @default(false) @map("is_profile_complete")
  preferredWorkMode  WorkMode   @default(ANY) @map("preferred_work_mode")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([careerScore])
  @@index([isProfileComplete])
  @@map("job_seeker_profiles")
}

model CandidateEducation {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  institution  String
  degree       String
  fieldOfStudy String?   @map("field_of_study")
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  grade        String?
  description  String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([endDate])
  @@map("candidate_educations")
}

model CandidateExperience {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  companyName      String    @map("company_name")
  title            String
  employmentType   String?   @map("employment_type")
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  isCurrent        Boolean   @default(false) @map("is_current")
  location         String?
  description      String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isCurrent])
  @@map("candidate_experiences")
}

model CandidateCertification {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  name             String
  issuer           String
  credentialId     String?   @map("credential_id")
  credentialUrl    String?   @map("credential_url")
  issueDate        DateTime? @map("issue_date")
  expiryDate       DateTime? @map("expiry_date")
  description      String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiryDate])
  @@map("candidate_certifications")
}

model CandidateProject {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  title            String
  description      String?   @db.Text
  skillsUsed       Json?     @map("skills_used")
  projectUrl       String?   @map("project_url")
  repositoryUrl    String?   @map("repository_url")
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("candidate_projects")
}

model Invite {
  id               String         @id @default(cuid())
  tenantId         String         @map("tenant_id")
  collegeProfileId String?        @map("college_profile_id")
  code             String         @unique
  maxUses          Int            @default(1) @map("max_uses")
  usedCount        Int            @default(0) @map("used_count")
  expiresAt        DateTime?      @map("expires_at")
  createdByUserId  String         @map("created_by_user_id")
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  collegeProfile   CollegeProfile? @relation(fields: [collegeProfileId], references: [id], onDelete: SetNull)
  createdBy        User           @relation("invite_creator", fields: [createdByUserId], references: [id], onDelete: Cascade)
