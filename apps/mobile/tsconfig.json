{
  "extends": "@campushire/config/tsconfig/base.json",
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["react", "react-native"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@campushire/types": ["../../packages/types/src/index.ts"],
      "@campushire/utils": ["../../packages/utils/src/index.ts"]
    }
  },
  "include": ["src/**/*", "expo-env.d.ts"],
  "exclude": ["node_modules"]
}
